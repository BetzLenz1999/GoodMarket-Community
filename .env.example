# Core chain config
CELO_RPC_URL=https://forno.celo.org

# UBI gas fallback (server-side)
GAMES_KEY=0xyour_games_private_key
GOODDOLLAR_FAUCET_CONTRACT=0x4F93Fa058b03953C851eFaA2e4FC5C34afDFAb84
GOODDOLLAR_FAUCET_API_URL=https://goodserver.gooddollar.org/verify/topWallet

# Fuse G$ claiming
# Fuse claiming is enabled by default for browser-extension / injected MetaMask
# and compatible WalletConnect wallets (MiniPay & Trust Wallet are filtered out
# client-side because they have no Fuse network). Set FUSE_CLAIM_ENABLED=false
# to hard-disable the whole network if the Fuse claim reserve runs low.
FUSE_CLAIM_ENABLED=true
# Gas faucet for Fuse claims: GoodDollar topWallet API is tried first, then the
# TOPWALLET_KEY signer is used as an on-chain fallback when the API is down.
TOPWALLET_KEY=0xyour_topwallet_private_key
GOODDOLLAR_FUSE_FAUCET_API_URL=https://goodserver.gooddollar.org/verify/topWallet
GOODDOLLAR_FUSE_FAUCET_CONTRACT=0x01ab5966C1d742Ae0CFF7f14cC0F4D85156e83d9
FAUCET_MIN_FUSE=0.003

# Optional faucet tuning
# FAUCET_MIN_CELO is the minimum-floor threshold for the gas readiness check.
# Wallets with balance below max(dynamic_required, FAUCET_MIN_CELO) trigger a
# faucet top-up. Default 0.1 CELO covers typical end-to-end claim cost during
# congestion (the previous 0.002–0.005 floors were too low and let WC / Trust
# users false-pass with only 0.06 CELO).
FAUCET_MIN_CELO=0.1
FAUCET_BUFFER_MULTIPLIER=1.35
FAUCET_DUPLICATE_WINDOW_MIN=30

# LI.FI / Jumper Buy Crypto widget (optional)
# All values default in code; LI.FI does NOT require contacting their team
# for an integrator ID — the field is just a self-chosen identifier sent
# in the `x-lifi-integrator` header. Override these only to change the
# default source/destination chain or to use a custom LI.FI endpoint.
LIFI_INTEGRATOR=goodmarket-community
LIFI_API_URL=https://li.quest/v1
LIFI_FROM_CHAIN_ID=42220
LIFI_TO_CHAIN_ID=8453
# Native-token sentinels (per LI.FI):
#   - Most EVM chains:       0x0000000000000000000000000000000000000000
#   - Celo (42220):          0x471EcE3750Da237f93B8E339c536989b8978a438
# Leave LIFI_FROM_TOKEN / LIFI_TO_TOKEN unset to let the server pick the
# correct sentinel per chain.
# LIFI_FROM_TOKEN=0x471EcE3750Da237f93B8E339c536989b8978a438
# LIFI_TO_TOKEN=0x0000000000000000000000000000000000000000
